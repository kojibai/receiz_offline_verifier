{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://receiz.com/schemas/receiz-proof-bundle.schema.json",
  "title": "Receiz Proof Bundle",
  "type": "object",
  "required": [
    "kind",
    "payloadVersion",
    "ts",
    "slug",
    "code",
    "kaiPulseEternal",
    "verifyPath",
    "artifactSha256Basis",
    "zkPoseidonHash",
    "groth16Proof",
    "groth16ProofDigest"
  ],
  "properties": {
    "kind": {
      "const": "receiz.proof_bundle"
    },
    "payloadVersion": {
      "enum": [
        "v1",
        "v2"
      ]
    },
    "ts": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "code": {
      "type": "string",
      "pattern": "^[A-Z0-9]{8}$"
    },
    "kaiPulseEternal": {
      "type": "string",
      "pattern": "^\\d+$"
    },
    "verifyPath": {
      "type": "string",
      "pattern": "^/v/[^/]+/[A-Z0-9]{8}/[0-9]+$"
    },
    "verifyUrl": {
      "type": "string"
    },
    "artifactSha256Basis": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "receizClaimId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{32}$"
    },
    "sigilClaimSeed": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "wireproof": {
      "type": "object",
      "properties": {
        "verifierPath": {
          "type": "string",
          "pattern": "^/"
        }
      },
      "additionalProperties": true
    },
    "zkPoseidonHash": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "groth16Proof": {
      "type": "string",
      "pattern": "^g16:[A-Za-z0-9_\\-+/]+={0,2}$"
    },
    "groth16ProofDigest": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "signatureV3": {
      "type": "object",
      "required": [
        "version",
        "alg",
        "kid",
        "sig",
        "payloadHashSha256",
        "signedAtMs"
      ],
      "properties": {
        "version": {
          "const": 1
        },
        "alg": {
          "const": "Ed25519"
        },
        "kid": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]{3,64}$"
        },
        "sig": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "payloadHashSha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "signedAtMs": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "signatureV4": {
      "type": "object",
      "required": [
        "version",
        "alg",
        "cert",
        "sig",
        "payloadHashSha256",
        "signedAtMs"
      ],
      "properties": {
        "version": {
          "const": 1
        },
        "alg": {
          "const": "Ed25519"
        },
        "cert": {
          "type": "object",
          "required": [
            "version",
            "certType",
            "certId",
            "issuerKid",
            "alg",
            "subjectPublicKeyRawB64u",
            "issuedAtMs",
            "expiresAtMs",
            "sig"
          ],
          "properties": {
            "version": {
              "const": 1
            },
            "certType": {
              "const": "receiz.device.v1"
            },
            "certId": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{32}$"
            },
            "issuerKid": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]{3,64}$"
            },
            "alg": {
              "const": "Ed25519"
            },
            "subjectPublicKeyRawB64u": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]+$"
            },
            "issuedAtMs": {
              "type": "integer",
              "minimum": 0
            },
            "expiresAtMs": {
              "type": "integer",
              "minimum": 0
            },
            "sig": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]+$"
            }
          },
          "additionalProperties": true
        },
        "sig": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "payloadHashSha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "signedAtMs": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    }
  },
  "anyOf": [
    {
      "required": [
        "signatureV3"
      ]
    },
    {
      "required": [
        "signatureV4"
      ]
    }
  ],
  "additionalProperties": true
}
